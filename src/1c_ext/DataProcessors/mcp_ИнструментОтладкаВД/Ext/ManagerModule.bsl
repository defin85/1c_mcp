	);

КонецПроцедуры

#КонецОбласти

#Область РеализацияИнструментов

Функция ВыполнитьЗапросТолькоЧтение(Аргументы)

	ТекстЗапроса = ПолучитьСтроковыйПараметр(Аргументы, "queryText");
	МаксимумСтрок = ПолучитьЧисловойПараметр(Аргументы, "maxRows", 200, 1, 500);

	ПроверитьЗапросНаЧтение(ТекстЗапроса);

	Запрос = Новый Запрос(ТекстЗапроса);
	ТаблицаРезультата = Запрос.Выполнить().Выгрузить();

	Результат = Новый Структура;
	Колонки = Новый Массив;
	Для Каждого Колонка Из ТаблицаРезультата.Колонки Цикл
		Колонки.Добавить(Колонка.Имя);
	КонецЦикла;

	Строки = Новый Массив;
	Счетчик = 0;
	Для Каждого СтрокаТаблицы Из ТаблицаРезультата Цикл
		Если Счетчик >= МаксимумСтрок Тогда
			Прервать;
		КонецЕсли;

		СтруктураСтроки = Новый Структура;
		Для Каждого Колонка Из ТаблицаРезультата.Колонки Цикл
			СтруктураСтроки.Вставить(Колонка.Имя, ПредставлениеЗначенияДляJSON(СтрокаТаблицы[Колонка.Имя]));
		КонецЦикла;

		Строки.Добавить(СтруктураСтроки);
		Счетчик = Счетчик + 1;
	КонецЦикла;

	Результат.Вставить("queryText", ТекстЗапроса);
	Результат.Вставить("columns", Колонки);
	Результат.Вставить("totalRows", ТаблицаРезультата.Количество());
	Результат.Вставить("returnedRows", Строки.Количество());
	Результат.Вставить("truncated", ТаблицаРезультата.Количество() > МаксимумСтрок);
	Результат.Вставить("rows", Строки);

	Возврат mcp_ОбщегоНазначения.СтруктураВJSON(Результат);

КонецФункции

Функция АнализПоступленияНаРасчетныйСчет(Аргументы)

	ИдентификаторДокумента = ПолучитьСтроковыйПараметр(Аргументы, "documentRef");
	ПараметрыДокумента = РазобратьИдентификаторПоступленияНаРасчетныйСчет(ИдентификаторДокумента);
	СсылкаНаДокумент = ПараметрыДокумента.Ссылка;
	ДокументОбъект = СсылкаНаДокумент.ПолучитьОбъект();

	Результат = Новый Структура;
	ИнформацияОДокументе = Новый Структура;
	НедоступныеПоляДокумента = Новый Массив;
	ИнформацияОДокументе.Вставить("ref", ИдентификаторДокумента);
	ИнформацияОДокументе.Вставить("inputKind", ПараметрыДокумента.ВидВхода);
	ИнформацияОДокументе.Вставить("resolvedGuid", ПараметрыДокумента.СтрокаGUID);
	ИнформацияОДокументе.Вставить("resolvedNavigationRef", ПараметрыДокумента.NavigationRef);
	Если ЗначениеЗаполнено(ПараметрыДокумента.MetadataPath) Тогда
		ИнформацияОДокументе.Вставить("resolvedMetadataPath", ПараметрыДокумента.MetadataPath);
	КонецЕсли;
	ИнформацияОДокументе.Вставить("number", ДокументОбъект.Номер);
	ИнформацияОДокументе.Вставить("date", ПредставлениеЗначенияДляJSON(ДокументОбъект.Дата));
	ИнформацияОДокументе.Вставить("posted", ДокументОбъект.Проведен);
	ИнформацияОДокументе.Вставить("organization", ПредставлениеЗначенияДляJSON(ДокументОбъект.Организация));
	ИнформацияОДокументе.Вставить("operation", ПредставлениеЗначенияДляJSON(ДокументОбъект.ВидОперации));
	Попытка
		ИнформацияОДокументе.Вставить("counterparty", ПредставлениеЗначенияДляJSON(ДокументОбъект.Контрагент));
	Исключение
		НедоступныеПоляДокумента.Добавить("Контрагент");
	КонецПопытки;
	Попытка
		ИнформацияОДокументе.Вставить("operationUH", ПредставлениеЗначенияДляJSON(ДокументОбъект.ВидОперацииУХ));
	Исключение
		НедоступныеПоляДокумента.Добавить("ВидОперацииУХ");
	КонецПопытки;
	Попытка
		ИнформацияОДокументе.Вставить("headerSettlementAccount", ПредставлениеЗначенияДляJSON(ДокументОбъект.СчетУчетаРасчетовСКонтрагентом));
	Исключение
		НедоступныеПоляДокумента.Добавить("СчетУчетаРасчетовСКонтрагентом");
	КонецПопытки;
	Если НедоступныеПоляДокумента.Количество() > 0 Тогда
		ИнформацияОДокументе.Вставить("unavailableFields", НедоступныеПоляДокумента);
	КонецЕсли;

	СтрокиРасшифровки = Новый Массив;
	НомерСтроки = 0;
	Для Каждого СтрокаРасшифровки Из ДокументОбъект.РасшифровкаПлатежа Цикл
		НомерСтроки = НомерСтроки + 1;
		ИнформацияОСтроке = Новый Структура;
		НедоступныеПоляСтроки = Новый Массив;
		ИнформацияОСтроке.Вставить("lineNo", НомерСтроки);
		ИнформацияОСтроке.Вставить("contract", ПредставлениеЗначенияДляJSON(СтрокаРасшифровки.ДоговорКонтрагента));
		ИнформацияОСтроке.Вставить("debtStructureElement", ПредставлениеЗначенияДляJSON(СтрокаРасшифровки.ЭлементСтруктурыЗадолженности));
		ИнформацияОСтроке.Вставить("settlementAccount", ПредставлениеЗначенияДляJSON(СтрокаРасшифровки.СчетУчетаРасчетовСКонтрагентом));
		ИнформацияОСтроке.Вставить("advanceAccount", ПредставлениеЗначенияДляJSON(СтрокаРасшифровки.СчетУчетаРасчетовПоАвансам));
		Попытка
			ИнформацияОСтроке.Вставить("counterparty", ПредставлениеЗначенияДляJSON(СтрокаРасшифровки.Контрагент));
		Исключение
			НедоступныеПоляСтроки.Добавить("Контрагент");
		КонецПопытки;
		Попытка
			ИнформацияОСтроке.Вставить("debtRepaymentMethod", ПредставлениеЗначенияДляJSON(СтрокаРасшифровки.СпособПогашенияЗадолженности));
		Исключение
			НедоступныеПоляСтроки.Добавить("СпособПогашенияЗадолженности");
		КонецПопытки;
		Попытка
			ИнформацияОСтроке.Вставить("analytics1", ПредставлениеЗначенияДляJSON(СтрокаРасшифровки.АналитикаБДДС1));
		Исключение
			НедоступныеПоляСтроки.Добавить("АналитикаБДДС1");
		КонецПопытки;
		Попытка
			ИнформацияОСтроке.Вставить("analytics2", ПредставлениеЗначенияДляJSON(СтрокаРасшифровки.АналитикаБДДС2));
		Исключение
			НедоступныеПоляСтроки.Добавить("АналитикаБДДС2");
		КонецПопытки;

		Если ЗначениеЗаполнено(СтрокаРасшифровки.ДоговорКонтрагента) Тогда
			ИнформацияОСтроке.Вставить("contractDetails", СведенияОДоговоре(СтрокаРасшифровки.ДоговорКонтрагента));
			ИнформацияОСтроке.Вставить("resolutionDiagnostics", ДиагностикаРазрешенияСчетов(ДокументОбъект, СтрокаРасшифровки));
		КонецЕсли;
		Если НедоступныеПоляСтроки.Количество() > 0 Тогда
			ИнформацияОСтроке.Вставить("unavailableFields", НедоступныеПоляСтроки);
		КонецЕсли;

		СтрокиРасшифровки.Добавить(ИнформацияОСтроке);
	КонецЦикла;

	Результат.Вставить("document", ИнформацияОДокументе);
	Результат.Вставить("paymentBreakdownRows", СтрокиРасшифровки);

	Возврат mcp_ОбщегоНазначения.СтруктураВJSON(Результат);

КонецФункции

Функция ТрассировкаЗаполненияСчетовПоступленияНаРасчетныйСчет(Аргументы)

	ИдентификаторДокумента = ПолучитьСтроковыйПараметр(Аргументы, "documentRef");
	НомерСтроки = ПолучитьЧисловойПараметр(Аргументы, "lineNo", 1, 1, 1000);
	ПараметрыДокумента = РазобратьИдентификаторПоступленияНаРасчетныйСчет(ИдентификаторДокумента);
	СсылкаНаДокумент = ПараметрыДокумента.Ссылка;
	ДокументОбъект = СсылкаНаДокумент.ПолучитьОбъект();

	Если ДокументОбъект.РасшифровкаПлатежа.Количество() < НомерСтроки Тогда
		ВызватьИсключение "В документе нет строки РасшифровкаПлатежа с номером " + Строка(НомерСтроки);
	КонецЕсли;

	СтрокаРасшифровки = ДокументОбъект.РасшифровкаПлатежа[НомерСтроки - 1];
	Результат = Новый Структура;

	Результат.Вставить("documentRef", ИдентификаторДокумента);
	Результат.Вставить("inputKind", ПараметрыДокумента.ВидВхода);
	Результат.Вставить("resolvedGuid", ПараметрыДокумента.СтрокаGUID);
	Результат.Вставить("resolvedNavigationRef", ПараметрыДокумента.NavigationRef);
	Если ЗначениеЗаполнено(ПараметрыДокумента.MetadataPath) Тогда
		Результат.Вставить("resolvedMetadataPath", ПараметрыДокумента.MetadataPath);
	КонецЕсли;
	Результат.Вставить("lineNo", НомерСтроки);
	Результат.Вставить("documentOrganization", ПредставлениеЗначенияДляJSON(ДокументОбъект.Организация));
	Результат.Вставить("documentCounterparty", ПредставлениеЗначенияДляJSON(ДокументОбъект.Контрагент));
	Результат.Вставить("contract", ПредставлениеЗначенияДляJSON(СтрокаРасшифровки.ДоговорКонтрагента));
	Результат.Вставить("currentSettlementAccount", ПредставлениеЗначенияДляJSON(СтрокаРасшифровки.СчетУчетаРасчетовСКонтрагентом));
	Результат.Вставить("currentAdvanceAccount", ПредставлениеЗначенияДляJSON(СтрокаРасшифровки.СчетУчетаРасчетовПоАвансам));

	Если ЗначениеЗаполнено(СтрокаРасшифровки.ДоговорКонтрагента) Тогда
		ДоговорОбъект = СтрокаРасшифровки.ДоговорКонтрагента.ПолучитьОбъект();
		КонтрагентПоДоговору = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтрокаРасшифровки.ДоговорКонтрагента, "Владелец");
		Результат.Вставить("contractOrganization", ПредставлениеЗначенияДляJSON(ДоговорОбъект.Организация));
		Результат.Вставить("contractCounterparty", ПредставлениеЗначенияДляJSON(КонтрагентПоДоговору));
		Результат.Вставить("contractCurrency", ПредставлениеЗначенияДляJSON(ДоговорОбъект.ВалютаВзаиморасчетов));
		Результат.Вставить("contractConditionalUnits", ПредставлениеЗначенияДляJSON(ДоговорОбъект.РасчетыВУсловныхЕдиницах));
		ВидРасчетов = БухгалтерскийУчетПереопределяемый.ОпределениеВидаРасчетовПоПараметрамДоговора(СтрокаРасшифровки.ДоговорКонтрагента);
		Результат.Вставить("contractSettlementType", ПредставлениеЗначенияДляJSON(ВидРасчетов));

		СчетаПоОрганизацииДокумента = БухгалтерскийУчетПереопределяемый.ПолучитьСчетаРасчетовСКонтрагентом(
			ДокументОбъект.Организация,
			КонтрагентПоДоговору,
			СтрокаРасшифровки.ДоговорКонтрагента);
		Результат.Вставить("accountsByDocumentOrganization", НормализоватьДляJSON(СчетаПоОрганизацииДокумента));

		Если ТипЗнч(ДоговорОбъект.Организация) = Тип("СправочникСсылка.Организации")
			И ЗначениеЗаполнено(ДоговорОбъект.Организация) Тогда
			СчетаПоОрганизацииДоговора = БухгалтерскийУчетПереопределяемый.ПолучитьСчетаРасчетовСКонтрагентом(
				ДоговорОбъект.Организация,
				КонтрагентПоДоговору,
				СтрокаРасшифровки.ДоговорКонтрагента);
			Результат.Вставить("accountsByContractOrganization", НормализоватьДляJSON(СчетаПоОрганизацииДоговора));
		КонецЕсли;

		ОсновныеСчета = Новый Структура;
		ОсновныеСчета.Вставить("settlementBuyer", ПредставлениеЗначенияДляJSON(УчетВзаиморасчетов.ОсновнойСчетРасчетов(ВидРасчетов, "РасчетыСПокупателем")));
		ОсновныеСчета.Вставить("advanceBuyer", ПредставлениеЗначенияДляJSON(УчетВзаиморасчетов.ОсновнойСчетРасчетов(ВидРасчетов, "АвансыПокупателя")));
		Результат.Вставить("defaultAccountsBySettlementType", ОсновныеСчета);

		Если ЗначениеЗаполнено(ДокументОбъект.ВидОперацииУХ) Тогда
			ПараметрыКредитнойЛогики = Новый Структура;
			ПараметрыКредитнойЛогики.Вставить("ДоговорКонтрагента", СтрокаРасшифровки.ДоговорКонтрагента);
			ПараметрыКредитнойЛогики.Вставить("ВидОперации", ДокументОбъект.ВидОперацииУХ);
			ПараметрыКредитнойЛогики.Вставить("ЭлементСтруктурыЗадолженности", СтрокаРасшифровки.ЭлементСтруктурыЗадолженности);
			Результат.Вставить("documentOperationUH", ПредставлениеЗначенияДляJSON(ДокументОбъект.ВидОперацииУХ));
			Результат.Вставить(
				"creditOverrideAccount",
				ПредставлениеЗначенияДляJSON(
					вд_ОбработкаЗаполненияФормВызовСервераПовтИсп.ПолучитьСчетУчетаПоступлениеСписаниеСРС(ПараметрыКредитнойЛогики)
				)
			);
		КонецЕсли;
	КонецЕсли;

	ДанныеФормыОбъект = Новый Структура;
	НедоступныеПоляОбъекта = Новый Массив;
	БезопасноВставитьРеквизитВСтруктуру(ДанныеФормыОбъект, ДокументОбъект, "ВидОперации", НедоступныеПоляОбъекта);
	БезопасноВставитьРеквизитВСтруктуру(ДанныеФормыОбъект, ДокументОбъект, "Организация", НедоступныеПоляОбъекта);
	БезопасноВставитьРеквизитВСтруктуру(ДанныеФормыОбъект, ДокументОбъект, "Контрагент", НедоступныеПоляОбъекта);
	БезопасноВставитьРеквизитВСтруктуру(ДанныеФормыОбъект, ДокументОбъект, "ОтражатьРазницуВКурсеВСоставеОперационныхРасходов", НедоступныеПоляОбъекта);
	БезопасноВставитьРеквизитВСтруктуру(ДанныеФормыОбъект, ДокументОбъект, "ВалютаДокумента", НедоступныеПоляОбъекта);

	ДанныеФормыСтрока = Новый Структура;
	НедоступныеПоляСтроки = Новый Массив;
	БезопасноВставитьРеквизитВСтруктуру(ДанныеФормыСтрока, СтрокаРасшифровки, "ДоговорКонтрагента", НедоступныеПоляСтроки);
	БезопасноВставитьРеквизитВСтруктуру(ДанныеФормыСтрока, СтрокаРасшифровки, "СчетУчетаРасчетовСКонтрагентом", НедоступныеПоляСтроки);
	БезопасноВставитьРеквизитВСтруктуру(ДанныеФормыСтрока, СтрокаРасшифровки, "СпособПогашенияЗадолженности", НедоступныеПоляСтроки);
	БезопасноВставитьРеквизитВСтруктуру(ДанныеФормыСтрока, СтрокаРасшифровки, "СчетУчетаРасчетовПоАвансам", НедоступныеПоляСтроки);

	ПараметрыЗаполненияСчетовУчета = СчетаУчетаВДокументахКлиентСервер.НовыйПараметрыЗаполнения(
		"ПоступлениеНаРасчетныйСчет",
		"РасшифровкаПлатежа.ДоговорКонтрагента",
		ДанныеФормыОбъект,
		ДанныеФормыСтрока,
		Неопределено,
		Неопределено);
	Если НЕ ПараметрыЗаполненияСчетовУчета.Свойство("Контейнер") Тогда
		ПараметрыЗаполненияСчетовУчета.Вставить("Контейнер", Новый Структура);
		ПараметрыЗаполненияСчетовУчета.Контейнер.Вставить("Объект", Новый Структура);
		ПараметрыЗаполненияСчетовУчета.Контейнер.Вставить("Строка", Новый Структура);
	КонецЕсли;

	СчетаУчетаВДокументахКлиентСервер.НачатьЗаполнениеРеквизита(ПараметрыЗаполненияСчетовУчета, "РасшифровкаПлатежа.СчетУчетаРасчетовСКонтрагентом");
	СчетаУчетаВДокументахКлиентСервер.НачатьЗаполнениеРеквизита(ПараметрыЗаполненияСчетовУчета, "РасшифровкаПлатежа.СчетУчетаРасчетовПоАвансам");
	СчетаУчетаВДокументахКлиентСервер.ДополнитьДанныеЗаполнения(ПараметрыЗаполненияСчетовУчета, "Строка", "ДоговорКонтрагента");
	СчетаУчетаВДокументахКлиентСервер.ДополнитьДанныеЗаполнения(ПараметрыЗаполненияСчетовУчета, "Строка", "СчетУчетаРасчетовСКонтрагентом");
	СчетаУчетаВДокументахКлиентСервер.ДополнитьДанныеЗаполнения(ПараметрыЗаполненияСчетовУчета, "Объект", "ВидОперации");
	СчетаУчетаВДокументахКлиентСервер.ДополнитьДанныеЗаполнения(ПараметрыЗаполненияСчетовУчета, "Строка", "СпособПогашенияЗадолженности");
	СчетаУчетаВДокументахКлиентСервер.ДополнитьДанныеЗаполнения(ПараметрыЗаполненияСчетовУчета, "Объект", "Организация");
	СчетаУчетаВДокументахКлиентСервер.ДополнитьДанныеЗаполнения(ПараметрыЗаполненияСчетовУчета, "Объект", "Контрагент");
	СчетаУчетаВДокументахКлиентСервер.ДополнитьДанныеЗаполнения(ПараметрыЗаполненияСчетовУчета, "Объект", "ОтражатьРазницуВКурсеВСоставеОперационныхРасходов");
	СчетаУчетаВДокументахКлиентСервер.ДополнитьДанныеЗаполнения(ПараметрыЗаполненияСчетовУчета, "Объект", "ВалютаДокумента");
	СчетаУчетаВДокументахКлиентСервер.ДополнитьДанныеЗаполнения(ПараметрыЗаполненияСчетовУчета, "Строка", "СчетУчетаРасчетовПоАвансам");

	Результат.Вставить("formDataObject", НормализоватьДляJSON(ДанныеФормыОбъект));
	Результат.Вставить("formDataRow", НормализоватьДляJSON(ДанныеФормыСтрока));
	Если НедоступныеПоляОбъекта.Количество() > 0 Тогда
		Результат.Вставить("unavailableObjectFields", НедоступныеПоляОбъекта);
	КонецЕсли;
	Если НедоступныеПоляСтроки.Количество() > 0 Тогда
		Результат.Вставить("unavailableRowFields", НедоступныеПоляСтроки);
	КонецЕсли;
	Результат.Вставить("fillKeys", ПолучитьКлючиСоответствия(ПараметрыЗаполненияСчетовУчета.КЗаполнению));

	Изменения = СчетаУчетаВДокументах.ЗаполнитьРеквизитыПриИзменении(
		Документы.ПоступлениеНаРасчетныйСчет,
		ПараметрыЗаполненияСчетовУчета.КЗаполнению,
		ДокументОбъект,
		"РасшифровкаПлатежа",
		СтрокаРасшифровки,
		Ложь);
	Результат.Вставить("fillChanges", НормализоватьДляJSON(Изменения));

	Возврат mcp_ОбщегоНазначения.СтруктураВJSON(Результат);

КонецФункции

#КонецОбласти

#Область СлужебныеФункции

Функция ПолучитьСсылкуНаПоступлениеНаРасчетныйСчет(СтроковыйИдентификатор)

	Возврат РазобратьИдентификаторПоступленияНаРасчетныйСчет(СтроковыйИдентификатор).Ссылка;

КонецФункции

Функция РазобратьИдентификаторПоступленияНаРасчетныйСчет(СтроковыйИдентификатор)

	ПараметрыИдентификатора = РазобратьИдентификаторОбъектаИБ(СтроковыйИдентификатор);

	Если ЗначениеЗаполнено(ПараметрыИдентификатора.MetadataPath)
		И НЕ ЭтоПутьМетаданныхПоступленияНаРасчетныйСчет(ПараметрыИдентификатора.MetadataPath) Тогда
		ВызватьИсключение "documentRef указывает не на Документ.ПоступлениеНаРасчетныйСчет: " + ПараметрыИдентификатора.MetadataPath;
	КонецЕсли;

	СсылкаНаДокумент = Документы.ПоступлениеНаРасчетныйСчет.ПолучитьСсылку(ПараметрыИдентификатора.GUID);
	Если СсылкаНаДокумент = Документы.ПоступлениеНаРасчетныйСчет.ПустаяСсылка() Тогда
		ВызватьИсключение "Документ ПоступлениеНаРасчетныйСчет не найден: " + СтроковыйИдентификатор;
	КонецЕсли;

	ПараметрыИдентификатора.Вставить("Ссылка", СсылкаНаДокумент);

	Возврат ПараметрыИдентификатора;

КонецФункции

Функция РазобратьИдентификаторОбъектаИБ(СтроковыйИдентификатор)

	ИсходнаяСтрока = СокрЛП(СтроковыйИдентификатор);
	НормализованнаяСтрока = ИсходнаяСтрока;
	ВидВхода = "guid";
	MetadataPath = "";
	NavigationRef = "";

	ПозицияФрагмента = СтрНайти(ВРег(НормализованнаяСтрока), "#E1CIB/");
	Если ПозицияФрагмента > 0 Тогда
		НормализованнаяСтрока = Сред(НормализованнаяСтрока, ПозицияФрагмента + 1);
		ВидВхода = "externalLink";
	КонецЕсли;

	Если Лев(ВРег(НормализованнаяСтрока), СтрДлина("E1CIB/DATA/")) = "E1CIB/DATA/" Тогда
		Если ВидВхода <> "externalLink" Тогда
			ВидВхода = "internalLink";
		КонецЕсли;

		ПараметрыНавигационнойСсылки = РазобратьНавигационнуюСсылкуНаОбъектИБ(НормализованнаяСтрока);
		MetadataPath = ПараметрыНавигационнойСсылки.MetadataPath;
		NavigationRef = ПараметрыНавигационнойСсылки.NavigationRef;
	ИначеЕсли ЭтоСтрокаGUID(НормализованнаяСтрока) Тогда
		NavigationRef = GUIDВNavigationRef(НормализованнаяСтрока);
	ИначеЕсли ЭтоNavigationRef(НормализованнаяСтрока) Тогда
		ВидВхода = "navigationRef";
		NavigationRef = ВРег(НормализованнаяСтрока);
	Иначе
		ВызватьИсключение "documentRef должен быть GUID, navigation-ref или e1cib-ссылкой документа ПоступлениеНаРасчетныйСчет.";
	КонецЕсли;

	СтрокаGUID = NavigationRefВGUID(NavigationRef);

	Попытка
		GUID = Новый УникальныйИдентификатор(СтрокаGUID);
	Исключение
		ВызватьИсключение "Не удалось преобразовать documentRef в GUID документа: " + ИсходнаяСтрока;
	КонецПопытки;

	Результат = Новый Структура;
	Результат.Вставить("ВидВхода", ВидВхода);
	Результат.Вставить("MetadataPath", MetadataPath);
	Результат.Вставить("NavigationRef", NavigationRef);
	Результат.Вставить("СтрокаGUID", СтрокаGUID);
	Результат.Вставить("GUID", GUID);

	Возврат Результат;

КонецФункции

Функция РазобратьНавигационнуюСсылкуНаОбъектИБ(НавигационнаяСсылка)

	ПозицияПути = СтрНайти(ВРег(НавигационнаяСсылка), "E1CIB/DATA/");
	Если ПозицияПути <> 1 Тогда
		ВызватьИсключение "Поддерживаются только ссылки формата e1cib/data/<metadata path>?ref=<navigation-ref>.";
	КонецЕсли;

	ПозицияВопроса = СтрНайти(НавигационнаяСсылка, "?");
	Если ПозицияВопроса = 0 Тогда
		ВызватьИсключение "В nav-ссылке отсутствует секция параметров: " + НавигационнаяСсылка;
	КонецЕсли;

	MetadataPath = Сред(НавигационнаяСсылка, СтрДлина("e1cib/data/") + 1, ПозицияВопроса - СтрДлина("e1cib/data/") - 1);
	СтрокаПараметров = Сред(НавигационнаяСсылка, ПозицияВопроса + 1);
	NavigationRef = ПолучитьЗначениеПараметраСтрокиЗапроса(СтрокаПараметров, "ref");
	Если НЕ ЭтоNavigationRef(NavigationRef) Тогда
		ВызватьИсключение "Параметр ref nav-ссылки должен быть 32-символьным navigation-ref объекта ИБ.";
	КонецЕсли;

	Результат = Новый Структура;
	Результат.Вставить("MetadataPath", MetadataPath);
	Результат.Вставить("NavigationRef", ВРег(NavigationRef));

	Возврат Результат;

КонецФункции

Функция ПолучитьЗначениеПараметраСтрокиЗапроса(СтрокаПараметров, ИмяПараметра)

	Для Каждого Параметр Из СтрРазделить(СтрокаПараметров, "&") Цикл
		ПозицияРавно = СтрНайти(Параметр, "=");
		Если ПозицияРавно = 0 Тогда
			Продолжить;
		КонецЕсли;

		Имя = Лев(Параметр, ПозицияРавно - 1);
		Если ВРег(Имя) = ВРег(ИмяПараметра) Тогда
			Возврат Сред(Параметр, ПозицияРавно + 1);
		КонецЕсли;
	КонецЦикла;

	ВызватьИсключение "В nav-ссылке отсутствует обязательный параметр " + ИмяПараметра + ".";

КонецФункции

Функция ЭтоПутьМетаданныхПоступленияНаРасчетныйСчет(ПутьМетаданных)

	Возврат ПутьМетаданных = "Документ.ПоступлениеНаРасчетныйСчет"
		Или ПутьМетаданных = "Document.ПоступлениеНаРасчетныйСчет";

КонецФункции

Функция ЭтоСтрокаGUID(ЗначениеСтрокой)

	Возврат СтрДлина(ЗначениеСтрокой) = 36
		И Сред(ЗначениеСтрокой, 9, 1) = "-"
		И Сред(ЗначениеСтрокой, 14, 1) = "-"
		И Сред(ЗначениеСтрокой, 19, 1) = "-"
		И Сред(ЗначениеСтрокой, 24, 1) = "-"
		И ЭтоHexСтрока(СтрЗаменить(ЗначениеСтрокой, "-", ""));

КонецФункции

Функция ЭтоNavigationRef(ЗначениеСтрокой)

	Возврат СтрДлина(ЗначениеСтрокой) = 32
		И ЭтоHexСтрока(ЗначениеСтрокой);

КонецФункции

Функция ЭтоHexСтрока(ЗначениеСтрокой)

	Если ПустаяСтрока(ЗначениеСтрокой) Тогда
		Возврат Ложь;
	КонецЕсли;

	ДопустимыеСимволы = "0123456789ABCDEF";
	ПроверяемаяСтрока = ВРег(ЗначениеСтрокой);
	Для НомерСимвола = 1 По СтрДлина(ПроверяемаяСтрока) Цикл
		Если СтрНайти(ДопустимыеСимволы, Сред(ПроверяемаяСтрока, НомерСимвола, 1)) = 0 Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЦикла;

	Возврат Истина;

КонецФункции

Функция NavigationRefВGUID(NavigationRef)

	NavigationRef = ВРег(NavigationRef);

	Возврат Сред(NavigationRef, 25, 8)
		+ "-" + Сред(NavigationRef, 21, 4)
		+ "-" + Сред(NavigationRef, 17, 4)
		+ "-" + Сред(NavigationRef, 1, 4)
		+ "-" + Сред(NavigationRef, 5, 12);

КонецФункции

Функция GUIDВNavigationRef(СтрокаGUID)

	ЧистыйGUID = ВРег(СтрЗаменить(СтрокаGUID, "-", ""));

	Возврат Сред(ЧистыйGUID, 17, 4)
		+ Сред(ЧистыйGUID, 21, 12)
		+ Сред(ЧистыйGUID, 13, 4)
		+ Сред(ЧистыйGUID, 9, 4)
		+ Сред(ЧистыйGUID, 1, 8);

КонецФункции

Функция СведенияОДоговоре(СсылкаНаДоговор)

	ДоговорОбъект = СсылкаНаДоговор.ПолучитьОбъект();
	Результат = Новый Структура;
	НедоступныеПоляДоговора = Новый Массив;
	Результат.Вставить("presentation", ПредставлениеЗначенияДляJSON(СсылкаНаДоговор));
	Результат.Вставить("organization", ПредставлениеЗначенияДляJSON(ДоговорОбъект.Организация));
	Результат.Вставить("contractType", ПредставлениеЗначенияДляJSON(ДоговорОбъект.ВидДоговора));
	Попытка
		Результат.Вставить("contractTypeUH", ПредставлениеЗначенияДляJSON(ДоговорОбъект.ВидДоговораУХ));
	Исключение
		НедоступныеПоляДоговора.Добавить("ВидДоговораУХ");
	КонецПопытки;
	Попытка
		Результат.Вставить("settlementCurrency", ПредставлениеЗначенияДляJSON(ДоговорОбъект.ВалютаВзаиморасчетов));
	Исключение
		НедоступныеПоляДоговора.Добавить("ВалютаВзаиморасчетов");
	КонецПопытки;
	Попытка
		Результат.Вставить("paymentInCurrency", ПредставлениеЗначенияДляJSON(ДоговорОбъект.ОплатаВВалюте));
	Исключение
		НедоступныеПоляДоговора.Добавить("ОплатаВВалюте");
	КонецПопытки;
	Попытка
		Результат.Вставить("settlementsInConditionalUnits", ПредставлениеЗначенияДляJSON(ДоговорОбъект.РасчетыВУсловныхЕдиницах));
	Исключение
		НедоступныеПоляДоговора.Добавить("РасчетыВУсловныхЕдиницах");
	КонецПопытки;
	Попытка
		Результат.Вставить("settlementsInConditionalUnitsCurrency", ПредставлениеЗначенияДляJSON(ДоговорОбъект.РасчетыВУсловныхЕдиницахВалюта));
	Исключение
		НедоступныеПоляДоговора.Добавить("РасчетыВУсловныхЕдиницахВалюта");
	КонецПопытки;
	Попытка
		Результат.Вставить("agreementVersion", ПредставлениеЗначенияДляJSON(ДоговорОбъект.ВерсияСоглашения));
		Результат.Вставить("agreementVersionType", Строка(ТипЗнч(ДоговорОбъект.ВерсияСоглашения)));
	Исключение
		НедоступныеПоляДоговора.Добавить("ВерсияСоглашения");
	КонецПопытки;
	Если НедоступныеПоляДоговора.Количество() > 0 Тогда
		Результат.Вставить("unavailableFields", НедоступныеПоляДоговора);
	КонецЕсли;

	Возврат Результат;

КонецФункции

Функция ДиагностикаРазрешенияСчетов(ДокументОбъект, СтрокаРасшифровки)

	Результат = Новый Структура;

	КонтрагентПоДоговору = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтрокаРасшифровки.ДоговорКонтрагента, "Владелец");
	ВидРасчетовПоДоговору = БухгалтерскийУчетПереопределяемый.ОпределениеВидаРасчетовПоПараметрамДоговора(
		СтрокаРасшифровки.ДоговорКонтрагента);
	НастройкаСчетов = БухгалтерскийУчетПереопределяемый.ПолучитьСчетаРасчетовСКонтрагентом(
		ДокументОбъект.Организация,
		КонтрагентПоДоговору,
		СтрокаРасшифровки.ДоговорКонтрагента);

	СчетРасчетовПоУмолчанию = УчетВзаиморасчетов.ОсновнойСчетРасчетов(
		ВидРасчетовПоДоговору,
		"РасчетыСПокупателем");
	СчетАвансовПоУмолчанию = УчетВзаиморасчетов.ОсновнойСчетРасчетов(
		ВидРасчетовПоДоговору,
		"АвансыПокупателя");

	ОжидаемыйСчетРасчетов = ?(
		ЗначениеЗаполнено(НастройкаСчетов.СчетРасчетовПокупателя),
		НастройкаСчетов.СчетРасчетовПокупателя,
		СчетРасчетовПоУмолчанию);
	ОжидаемыйСчетАвансов = ?(
		ЗначениеЗаполнено(НастройкаСчетов.СчетАвансовПокупателя),
		НастройкаСчетов.СчетАвансовПокупателя,
		СчетАвансовПоУмолчанию);

	Результат.Вставить("lookupArguments", Новый Структура(
		"organization, contractCounterparty, contract",
		ПредставлениеЗначенияДляJSON(ДокументОбъект.Организация),
		ПредставлениеЗначенияДляJSON(КонтрагентПоДоговору),
		ПредставлениеЗначенияДляJSON(СтрокаРасшифровки.ДоговорКонтрагента)
	));
	Результат.Вставить("settlementTypeByContract", ПредставлениеЗначенияДляJSON(ВидРасчетовПоДоговору));
	Результат.Вставить("settingsLookupResult", Новый Структура(
		"buyerSettlement, buyerAdvance, supplierSettlement, supplierAdvance",
		ПредставлениеЗначенияДляJSON(НастройкаСчетов.СчетРасчетовПокупателя),
		ПредставлениеЗначенияДляJSON(НастройкаСчетов.СчетАвансовПокупателя),
		ПредставлениеЗначенияДляJSON(НастройкаСчетов.СчетРасчетов),
		ПредставлениеЗначенияДляJSON(НастройкаСчетов.СчетАвансов)
	));
	Результат.Вставить("fallbackAccounts", Новый Структура(
		"buyerSettlement, buyerAdvance",
		ПредставлениеЗначенияДляJSON(СчетРасчетовПоУмолчанию),
		ПредставлениеЗначенияДляJSON(СчетАвансовПоУмолчанию)
	));
	Результат.Вставить("expectedAccounts", Новый Структура(
		"buyerSettlement, buyerAdvance, buyerSettlementSource, buyerAdvanceSource",
		ПредставлениеЗначенияДляJSON(ОжидаемыйСчетРасчетов),
		ПредставлениеЗначенияДляJSON(ОжидаемыйСчетАвансов),
		?(ЗначениеЗаполнено(НастройкаСчетов.СчетРасчетовПокупателя), "settings", "fallback"),
		?(ЗначениеЗаполнено(НастройкаСчетов.СчетАвансовПокупателя), "settings", "fallback")
	));
	Результат.Вставить("matchesCurrentLine", Новый Структура(
		"buyerSettlement, buyerAdvance",
		СтрокаРасшифровки.СчетУчетаРасчетовСКонтрагентом = ОжидаемыйСчетРасчетов,
		СтрокаРасшифровки.СчетУчетаРасчетовПоАвансам = ОжидаемыйСчетАвансов
	));

	Возврат Результат;

КонецФункции

Функция ПолучитьСтроковыйПараметр(Аргументы, ИмяПараметра)

	Если НЕ Аргументы.Свойство(ИмяПараметра) Тогда
		ВызватьИсключение "Не указан обязательный параметр: " + ИмяПараметра;
	КонецЕсли;

	ЗначениеПараметра = СокрЛП(Строка(Аргументы[ИмяПараметра]));
	Если ПустаяСтрока(ЗначениеПараметра) Тогда
		ВызватьИсключение "Параметр " + ИмяПараметра + " не должен быть пустым.";
	КонецЕсли;

	Возврат ЗначениеПараметра;

КонецФункции

Функция ПолучитьЧисловойПараметр(Аргументы, ИмяПараметра, ЗначениеПоУмолчанию, Минимум, Максимум)

	Если НЕ Аргументы.Свойство(ИмяПараметра) Тогда
		Возврат ЗначениеПоУмолчанию;
	КонецЕсли;

	Попытка
		ЗначениеПараметра = Число(Аргументы[ИмяПараметра]);
	Исключение
		Возврат ЗначениеПоУмолчанию;
	КонецПопытки;

	Если ЗначениеПараметра < Минимум Тогда
		Возврат Минимум;
	КонецЕсли;
	Если ЗначениеПараметра > Максимум Тогда
		Возврат Максимум;
	КонецЕсли;

	Возврат ЗначениеПараметра;

КонецФункции

Процедура ПроверитьЗапросНаЧтение(ТекстЗапроса)

	НормализованныйЗапрос = ВРег(СокрЛП(ТекстЗапроса));
	Если Лев(НормализованныйЗапрос, СтрДлина("ВЫБРАТЬ")) <> "ВЫБРАТЬ" Тогда
		ВызватьИсключение "Разрешены только запросы на чтение, начинающиеся с ВЫБРАТЬ.";
	КонецЕсли;

	ЗапрещенныеКлючевыеСлова = Новый Массив;
	ЗапрещенныеКлючевыеСлова.Добавить("УНИЧТОЖИТЬ");
	ЗапрещенныеКлючевыеСлова.Добавить("ИЗМЕНИТЬ");
	ЗапрещенныеКлючевыеСлова.Добавить("ОБНОВИТЬ");
	ЗапрещенныеКлючевыеСлова.Добавить("ВСТАВИТЬ");
	ЗапрещенныеКлючевыеСлова.Добавить("УДАЛИТЬ");

	Для Каждого КлючевоеСлово Из ЗапрещенныеКлючевыеСлова Цикл
		Если СтрНайти(НормализованныйЗапрос, КлючевоеСлово) > 0 Тогда
			ВызватьИсключение "Запрос содержит запрещенное ключевое слово: " + КлючевоеСлово;
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

Функция ПредставлениеЗначенияДляJSON(Значение)

	Если Значение = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;

	ТипЗначения = ТипЗнч(Значение);
	Если ТипЗначения = Тип("Строка")
		Или ТипЗначения = Тип("Число")
		Или ТипЗначения = Тип("Булево") Тогда
		Возврат Значение;
	КонецЕсли;

	Если ТипЗначения = Тип("Дата") Тогда
		Возврат Формат(Значение, "ДФ=yyyy-MM-dd HH:mm:ss");
	КонецЕсли;

	Если ТипЗначения = Тип("УникальныйИдентификатор") Тогда
		Возврат Строка(Значение);
	КонецЕсли;

	Возврат Строка(Значение);

КонецФункции

Функция НормализоватьДляJSON(Значение)

	Если Значение = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;

	ТипЗначения = ТипЗнч(Значение);

	Если ТипЗначения = Тип("Структура") Тогда
		Результат = Новый Структура;
		Для Каждого Элемент Из Значение Цикл
			Результат.Вставить(Элемент.Ключ, НормализоватьДляJSON(Элемент.Значение));
		КонецЦикла;
		Возврат Результат;
	КонецЕсли;

	Если ТипЗначения = Тип("Соответствие") Тогда
		Результат = Новый Структура;
		Для Каждого Элемент Из Значение Цикл
			Результат.Вставить(Строка(Элемент.Ключ), НормализоватьДляJSON(Элемент.Значение));
		КонецЦикла;
		Возврат Результат;
	КонецЕсли;

	Если ТипЗначения = Тип("Массив") Тогда
		Результат = Новый Массив;
		Для Каждого Элемент Из Значение Цикл
			Результат.Добавить(НормализоватьДляJSON(Элемент));
		КонецЦикла;
		Возврат Результат;
	КонецЕсли;

	Возврат ПредставлениеЗначенияДляJSON(Значение);

КонецФункции

Функция ПолучитьКлючиСоответствия(СоответствиеЗначений)

	Результат = Новый Массив;
	Для Каждого Элемент Из СоответствиеЗначений Цикл
		Результат.Добавить(Строка(Элемент.Ключ));
	КонецЦикла;

	Возврат Результат;

КонецФункции

Процедура БезопасноВставитьРеквизитВСтруктуру(ЦелеваяСтруктура, Источник, ИмяРеквизита, НедоступныеПоля = Неопределено)

	Попытка
		ЦелеваяСтруктура.Вставить(ИмяРеквизита, Источник[ИмяРеквизита]);
	Исключение
		Если НедоступныеПоля <> Неопределено Тогда
			НедоступныеПоля.Добавить(ИмяРеквизита);
		КонецЕсли;
	КонецПопытки;

КонецПроцедуры

#КонецОбласти
