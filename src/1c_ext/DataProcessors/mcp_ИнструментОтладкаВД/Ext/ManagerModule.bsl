#Область ПрограммныйИнтерфейс

Процедура ДобавитьИнструменты(Инструменты) Экспорт

	ДобавитьИнструментВыполнитьЗапрос(Инструменты);
	ДобавитьИнструментАнализПоступленияНаРасчетныйСчет(Инструменты);
	ДобавитьИнструментТрассировкаЗаполненияСчетов(Инструменты);

КонецПроцедуры

Функция ВыполнитьИнструмент(ИмяИнструмента, Аргументы) Экспорт

	Если ИмяИнструмента = "run_select_query" Тогда
		Возврат ВыполнитьЗапросТолькоЧтение(Аргументы);
	ИначеЕсли ИмяИнструмента = "analyze_receipt_payment_accounts" Тогда
		Возврат АнализПоступленияНаРасчетныйСчет(Аргументы);
	ИначеЕсли ИмяИнструмента = "trace_receipt_account_fill" Тогда
		Возврат ТрассировкаЗаполненияСчетовПоступленияНаРасчетныйСчет(Аргументы);
	Иначе
		ВызватьИсключение "Неизвестный инструмент: " + ИмяИнструмента;
	КонецЕсли;

КонецФункции

#КонецОбласти

#Область ОписаниеИнструментов

Процедура ДобавитьИнструментВыполнитьЗапрос(Инструменты)

	МассивПараметров = Новый Массив;
	МассивПараметров.Добавить(
		mcp_Метаданные.ПараметрИнструмента(
			"queryText",
			"string",
			"Текст запроса 1С. Разрешены только запросы на чтение, начинающиеся с ВЫБРАТЬ.",
			,
			Истина
		)
	);
	МассивПараметров.Добавить(
		mcp_Метаданные.ПараметрИнструмента(
			"maxRows",
			"number",
			"Максимальное количество строк в результате.",
			200
		)
	);

	СхемаПараметров = mcp_Метаданные.СхемаПараметровИнструмента(МассивПараметров);

	mcp_Метаданные.ДобавитьИнструмент(
		Инструменты,
		"run_select_query",
		"Выполняет запрос 1С только на чтение и возвращает первые строки результата в JSON.",
		СхемаПараметров
	);

КонецПроцедуры

Процедура ДобавитьИнструментАнализПоступленияНаРасчетныйСчет(Инструменты)

	МассивПараметров = Новый Массив;
	МассивПараметров.Добавить(
		mcp_Метаданные.ПараметрИнструмента(
			"documentRef",
			"string",
			"GUID, navigation-ref или e1cib-ссылка документа ПоступлениеНаРасчетныйСчет.",
			,
			Истина
		)
	);

	СхемаПараметров = mcp_Метаданные.СхемаПараметровИнструмента(МассивПараметров);

	mcp_Метаданные.ДобавитьИнструмент(
		Инструменты,
		"analyze_receipt_payment_accounts",
		"Возвращает шапку, строки расшифровки платежа и ключевые сведения по договорам для документа ПоступлениеНаРасчетныйСчет.",
		СхемаПараметров
	);

	КонецПроцедуры

Процедура ДобавитьИнструментТрассировкаЗаполненияСчетов(Инструменты)

	МассивПараметров = Новый Массив;
	МассивПараметров.Добавить(
		mcp_Метаданные.ПараметрИнструмента(
			"documentRef",
			"string",
			"GUID, navigation-ref или e1cib-ссылка документа ПоступлениеНаРасчетныйСчет.",
